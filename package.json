{
  "name": "pr-rosey",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first Electron app for monitoring the current GitHub user's pull requests.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @pr-rosey/desktop",
    "build": "npm run build --workspace @pr-rosey/desktop",
    "start": "npm run start --workspace @pr-rosey/desktop",
    "typecheck": "tsgo --noEmit -p tsconfig.json && npm run typecheck --workspace @pr-rosey/desktop",
    "format": "biome format --write .",
    "lint": "biome check .",
    "check": "npm run lint && npm run typecheck && npm test -- --run",
    "test": "npm run test --workspaces --if-present --",
    "pr-watch": "node packages/pr-watch/src/cli.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/node": "^24.3.0",
    "@typescript/native-preview": "^7.0.0-dev.20260527.2",
    "vitest": "^3.2.4"
  }
}
