{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "paths": {
      "@pr-rosey/desktop/*": ["./apps/desktop/src/*"],
      "@pr-rosey/pr-watch": ["./packages/pr-watch/src/index.ts"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vitest/globals", "node", "electron", "electron-vite/node"]
  },
  "include": ["apps/**/*.ts", "apps/**/*.tsx", "skills/**/*.ts", "packages/**/*.ts"]
}
